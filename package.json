{
  "private": true,
  "scripts": {
    "build": "npx tailwindcss -i ./assets/index.css -o ./assets/css/site.css --minify",
    "build:dev": "npx tailwindcss -i ./assets/index.css -o ./assets/css/site.css",
    "watch": "npx tailwindcss -i ./assets/index.css -o ./assets/css/site.css --watch",
    "test:responsive": "npm run build && bundle exec jekyll build --strict_front_matter && node ./scripts/responsive-check.mjs"
  },
  "devDependencies": {
    "playwright": "^1.56.1",
    "tailwindcss": "^3.4.17"
  }
}
