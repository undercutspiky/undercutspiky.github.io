{
  "private": true,
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./assets/index.css -o ./assets/css/site.css --minify",
    "build:dev": "npx @tailwindcss/cli -i ./assets/index.css -o ./assets/css/site.css",
    "watch": "npx @tailwindcss/cli -i ./assets/index.css -o ./assets/css/site.css --watch",
    "test:responsive:check": "node ./scripts/responsive-check.mjs",
    "test:responsive": "npm run build && bundle exec jekyll build --strict_front_matter && npm run test:responsive:check"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.3"
  }
}
